{
  "server": {
    "listen": "127.0.0.1:9090"
  },
  "store": {
    "backend": "file",
    "path": "/data/phoenix/store.json",
    "master_key": "/data/phoenix/master.key"
  },
  "crypto": {
    "provider": "file"
  },
  "auth": {
    "bearer": {
      "enabled": true
    },
    "mtls": {
      "enabled": false,
      "require": false
    }
  },
  "acl": {
    "path": "/data/phoenix/acl.json"
  },
  "audit": {
    "path": "/data/phoenix/audit.log"
  },
  "policy": {
    "path": "/data/phoenix/policy.json"
  },
  "attestation": {
    "nonce": {
      "enabled": false,
      "max_age": "30s"
    },
    "token": {
      "enabled": false,
      "ttl": "15m"
    },
    "local_agent": {
      "enabled": false,
      "socket_path": "/tmp/phoenix-agent.sock"
    }
  },
  "session": {
    "enabled": false,
    "ttl": "1h",
    "roles": {
      "dev": {
        "namespaces": [
          "dev/*",
          "staging/*"
        ],
        "actions": [
          "list",
          "read_value"
        ],
        "bootstrap_trust": [
          "bearer"
        ]
      },
      "deploy": {
        "namespaces": [
          "prod/*"
        ],
        "actions": [
          "list",
          "read_value"
        ],
        "bootstrap_trust": [
          "mtls"
        ],
        "require_seal_key": true,
        "step_up": true,
        "step_up_ttl": "15m"
      }
    }
  },
  "dashboard": {
    "enabled": false,
    "password_hash": "",
    "session_ttl": "4h"
  },
  "onepassword": {
    "vault": "Engineering",
    "service_account_token_env": "OP_SERVICE_ACCOUNT_TOKEN",
    "cache_ttl": "60s"
  }
}
